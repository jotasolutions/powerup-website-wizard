# PostHog analytics — plantilla para desarrollo local (ver DEPLOY.md para despliegue)
VITE_PUBLIC_POSTHOG_PROJECT_TOKEN=
VITE_PUBLIC_POSTHOG_HOST=https://eu.i.posthog.com
# app_env en cliente PostHog (solo necesario en deploy Production; ver DEPLOY.md)
VITE_VERCEL_ENV=

# Panel interno Diagnóstico Alta (solo servidor; HogQL read)
POSTHOG_PERSONAL_API_KEY=
POSTHOG_API_HOST=https://eu.posthog.com
POSTHOG_PROJECT_ID=212884
INTERNAL_ANALYTICS_PANEL_SLUG=m4x8nq2k
# URL pública de una playlist de Session Replay en PostHog EU (tile «Grabaciones» del panel).
# Crear en https://eu.posthog.com/project/212884/replay → filtrar → «Save as playlist» → copiar URL.
# Filtro recomendado (tile 3.4): evento wizard_checkout_started SIN alta_fulfilled, recientes primero.
INTERNAL_ANALYTICS_REPLAY_URL=
ANALYTICS_CHECKOUT_SCENARIO_SINCE=2026-07-07

# Neon Postgres (connection string: postgresql://user:pass@host.neon.tech/db?sslmode=require)
# Acepta también POSTGRES_URL, NEON_DATABASE_URL, etc. (ver getDatabaseUrl en env.server.ts)
DATABASE_URL=

# Stripe — checkout; en local: stripe listen --forward-to localhost:8080/api/stripe/webhook
STRIPE_SECRET_KEY=
STRIPE_PRICE_PRO_MONTHLY=
STRIPE_PRICE_PRO_QUARTERLY=
STRIPE_PRICE_PRO_YEARLY=
STRIPE_PRICE_PRO_ANUAL=

# Webhook Stripe (fulfillment autoritativo). Local: stripe listen --forward-to localhost:8080/api/stripe/webhook
STRIPE_WEBHOOK_SECRET=

# Slack — notificaciones de lead y alta pagada (Incoming Webhook del canal)
SLACK_WEBHOOK_URL=

# Brevo — correos transaccionales al cliente (confirmación checkout + entrega web)
BREVO_API_KEY=
BREVO_SENDER_EMAIL=info@powerup.menu
BREVO_SENDER_NAME=PowerUp Menu
# Opcional: IDs de plantillas creadas en Brevo (si faltan, se usa HTML generado por el servidor)
BREVO_TEMPLATE_CHECKOUT_PAID=
BREVO_TEMPLATE_CHECKOUT_TRIAL=
BREVO_TEMPLATE_CHECKOUT_UPGRADE=
BREVO_TEMPLATE_SITE_DELIVERED=
# Local: redirige todos los correos transaccionales a esta bandeja (útil con mock checkout sin email Stripe)
BREVO_DEV_OVERRIDE_EMAIL=
# Webhook rebotes transaccionales — URL: https://tu-dominio/api/brevo/webhook?token=...
BREVO_WEBHOOK_TOKEN=

# Google Places — obligatorio para búsqueda de restaurantes (Places API New)
GOOGLE_PLACES_API_KEY=
GOOGLE_API_KEY=
NEXT_PUBLIC_GOOGLE_API_KEY=
VITE_GOOGLE_API_KEY=

# URL pública de la app (Stripe success/cancel). En local usa el puerto real del dev server
# (p. ej. 8081 si 8080 está ocupado) o deja que el cliente envíe window.location.origin.
APP_URL=http://localhost:8080

# Evolution API — validar números de WhatsApp (instancia conectada + API key)
EVOLUTION_API_URL=
EVOLUTION_INSTANCE_NAME=
EVOLUTION_API_KEY=
# Prueba local sin Evolution: usa un móvil solo con ceros (ej. 000000000) en el wizard

# WhatsApp del equipo de soporte (solo dígitos, ej. 34651332202)
SUPPORT_WHATSAPP=34651332202
VITE_SUPPORT_WHATSAPP=34651332202

# Namecheap API — comprobación real de dominios
NAMECHEAP_API_USER=
NAMECHEAP_API_KEY=
NAMECHEAP_CLIENT_IP=
NAMECHEAP_SANDBOX=false
NAMECHEAP_DOMAIN_MARGIN_PERCENT=20
NAMECHEAP_USD_TO_EUR=0.92
MOCK_DOMAIN_CHECK=false
